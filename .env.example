# --- Supabase (shared City Center project) ---
SUPABASE_URL=https://tsnbktwryvnbmgsvzxdt.supabase.co
# Project → Settings → API → JWT Secret (used to verify caller access tokens)
SUPABASE_JWT_SECRET=
# Service role key — server-side only, never shipped to clients
SUPABASE_SERVICE_ROLE_KEY=

# --- Model ---
# turbo (350M, low latency) | original (500M, controls) | multilingual (500M, 23+ langs)
CHATTERBOX_VARIANT=turbo
DEVICE=cuda

# --- Service ---
# Comma-separated allowed origins (the ecosystem app domains)
ALLOWED_ORIGINS=https://prayer.lifedailyos.app,https://app.deeplysmart.app
MAX_TTS_CHARS=2000
MAX_CLONE_SECONDS=60

# --- Storage buckets (must be PRIVATE) ---
AUDIO_CACHE_BUCKET=creed-audio-cache
VOICE_SAMPLES_BUCKET=voice-samples
